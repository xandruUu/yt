# App
APP_UI_LANGUAGE=es
SHOW_LEGACY_MODULES=false
CONTENT_LANGUAGE=en
TARGET_MARKET=global
APP_ENV=development

# Database
DATABASE_URL=sqlite:///data/shorts_factory.db
# DATABASE_URL=postgresql+psycopg://shorts:shorts@localhost:5432/shorts_factory
DATABASE_SCHEMA=shortsfactory_runtime

# Storage
ASSETS_DIR=assets
OUTPUTS_DIR=outputs
OUTPUT_DIR=outputs
EXPORTS_DIR=exports
MAX_UPLOAD_MB=250

# Ollama
ENABLE_OLLAMA_LLM=true
ENABLE_OLLAMA=true
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gpt-oss:20b
OLLAMA_NUM_CTX=16384
OLLAMA_TEMPERATURE_RESEARCH=0.75
OLLAMA_TEMPERATURE_METADATA=0.65
OLLAMA_TEMPERATURE_SCRIPT=0.55
OLLAMA_TEMPERATURE_SCENES=0.55
OLLAMA_TEMPERATURE_PROMPTS=0.40
OLLAMA_TIMEOUT_SECONDS=180

# Optional OpenAI fallback
ENABLE_OPENAI_LLM=false
OPENAI_API_KEY=
OPENAI_TEXT_MODEL=
OPENAI_TTS_MODEL=
OPENAI_TTS_VOICE=
ENABLE_OPENAI_TTS=false

# YouTube Data API
ENABLE_YOUTUBE_PROVIDER=false
YOUTUBE_API_KEY=
YOUTUBE_REGION_CODE=US
YOUTUBE_LOOKBACK_DAYS=30
YOUTUBE_MAX_RESULTS_PER_QUERY=25

# RSS / News
ENABLE_RSS_PROVIDER=true
RSS_FEEDS_FILE=config/rss_sources.json
ENABLE_NEWS_PROVIDER=false
NEWS_API_KEY=

# Hacker News
ENABLE_HACKERNEWS_PROVIDER=true
HACKERNEWS_LOOKBACK_DAYS=30

# TikTok Research API optional
ENABLE_TIKTOK_RESEARCH_PROVIDER=false
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_ACCESS_TOKEN=
TIKTOK_LOOKBACK_DAYS=30

# Google Trends optional
ENABLE_GOOGLE_TRENDS_PROVIDER=false
GOOGLE_TRENDS_REGION=US

# Instagram optional/manual
ENABLE_INSTAGRAM_PROVIDER=false
INSTAGRAM_ACCESS_TOKEN=

# ElevenLabs
ENABLE_ELEVENLABS=true
ENABLE_ELEVENLABS_TTS=true
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_DEFAULT_VOICE_ID=
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128
ELEVENLABS_STABILITY=0.45
ELEVENLABS_SIMILARITY_BOOST=0.80
ELEVENLABS_STYLE=0.25
ELEVENLABS_USE_SPEAKER_BOOST=true
ELEVENLABS_MAX_CHARS_PER_REQUEST=5000
ELEVENLABS_CONFIRM_COST_ABOVE_USD=1.00
ELEVENLABS_REQUIRE_CONFIRMATION=true
ELEVENLABS_ESTIMATED_COST_PER_1000_CHARS=0

# Local/manual TTS
DEFAULT_TTS_PROVIDER=manual
ENABLE_LOCAL_TTS=false
PIPER_TTS_PATH=
PYTTSX3_ENABLED=false

# Higgsfield
ENABLE_HIGGSFIELD_AUTOMATION=true
HIGGSFIELD_AUTOMATION_MODE=cli
HIGGSFIELD_CLI_BIN=higgsfield
HIGGSFIELD_SKILLS_ENABLED=true
HIGGSFIELD_REAL_GENERATION_ENABLED=false
HIGGSFIELD_DEFAULT_MODEL=veo3_1_lite
HIGGSFIELD_DEFAULT_TEST_DURATION_SECONDS=4
HIGGSFIELD_WAIT_TIMEOUT=20m
HIGGSFIELD_WAIT_INTERVAL=5s
HIGGSFIELD_KNOWN_CREDIT_BALANCE=10
HIGGSFIELD_DOWNLOAD_OUTPUTS=true
HIGGSFIELD_DEFAULT_ASPECT_RATIO=9:16
HIGGSFIELD_DEFAULT_DURATION_SECONDS=8
HIGGSFIELD_MAX_SCENE_DURATION_SECONDS=15
HIGGSFIELD_CONFIRM_CREDITS_ABOVE=10
HIGGSFIELD_DOWNLOAD_DIR=assets/higgsfield_clips
HIGGSFIELD_POLL_INTERVAL_SECONDS=20
HIGGSFIELD_JOB_TIMEOUT_SECONDS=1800
ENABLE_HIGGSFIELD_MANUAL=true
ENABLE_HIGGSFIELD_MCP=false
HIGGSFIELD_MCP_URL=https://mcp.higgsfield.ai/mcp
HIGGSFIELD_OUTPUT_DIR=external_outputs/higgsfield

# Picsart optional
ENABLE_PICSART=false
ENABLE_PICSART_MANUAL=true
ENABLE_PICSART_API=false
PICSART_API_KEY=
PICSART_OUTPUT_DIR=external_outputs/picsart

# Obsidian
ENABLE_OBSIDIAN_SYNC=true
OBSIDIAN_VAULT_PATH=C:/Users/<USER>/Documents/ShortsFactoryBrain
OBSIDIAN_AUTO_EXPORT_ON_APPROVAL=true
OBSIDIAN_IMPORT_NOTES=true

# Render
FFMPEG_BIN=ffmpeg
FFPROBE_BIN=ffprobe
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe
RENDER_WIDTH=1080
RENDER_HEIGHT=1920
RENDER_FPS=30
DEFAULT_VIDEO_WIDTH=1080
DEFAULT_VIDEO_HEIGHT=1920
DEFAULT_FPS=30
DEFAULT_VIDEO_DURATION_SECONDS=60
TARGET_DURATION_SECONDS=60
MAX_VIDEO_DURATION_SECONDS=90

# Audio mix
DEFAULT_MUSIC_VOLUME=0.12
DEFAULT_VOICE_VOLUME=1.0

# External integrations general
ENABLE_EXTERNAL_TOOLS=true
DEFAULT_EXTERNAL_MODE=manual

# Safety / Costs
ENABLE_COST_GUARDRAILS=true
DAILY_MAX_EXTERNAL_COST_USD=5.00
DAILY_MAX_HIGGSFIELD_CREDITS=50
DAILY_MAX_ELEVENLABS_CHARS=20000
REQUIRE_CONFIRMATION_FOR_EXTERNAL_JOBS=true
REQUIRE_CONFIRMATION_FOR_PAID_TOOLS=true
MAX_ESTIMATED_COST_PER_JOB=1.00
COST_CURRENCY=USD

# Import safety
MAX_IMPORTED_ASSET_MB=500
ALLOWED_VIDEO_EXTENSIONS=.mp4,.mov,.webm
ALLOWED_AUDIO_EXTENSIONS=.mp3,.wav,.m4a,.aac,.ogg
ALLOWED_IMAGE_EXTENSIONS=.png,.jpg,.jpeg,.webp

# Reddit optional legacy provider
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=ShortsFactoryLocal/1.0
